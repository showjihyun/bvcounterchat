{
  "name": "chatstrike",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "채팅이 중심인 웹 기반 10인 FFA 3D FPS 게임",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/showjihyun/bvcounterchat.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "vite build --config vite.server.config.ts",
    "start": "node dist/server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bash scripts/check.sh",
    "gate": "python .claude/hooks/gate_spec_freeze.py --check"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.76",
    "@colyseus/ws-transport": "^0.16.5",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@react-three/fiber": "^9.6.1",
    "colyseus": "^0.16.5",
    "colyseus.js": "^0.16.22",
    "fastify": "^5.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
